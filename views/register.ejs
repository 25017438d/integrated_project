<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>
  <nav>
    <a href="/">Home</a>
    <a href="/notices">Notices</a>
    <a href="/notices/new">Create Notice</a>
    <% if (user) { %>
      <a href="/profile">Profile</a>
      <a href="/logout">Logout (<%= user.nickname %>)</a>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    <% } %>
  </nav>
  <main>
    <div class="form-container">
      <h2>Register</h2>
      <form method="POST" action="/register" class="form">
        <div class="form-group">
          <label for="login_id">Login ID:</label>
          <input class="form-input" id="login_id" name="login_id" placeholder="Login ID (min 3 characters)" required />
        </div>
        
        <div class="form-group">
          <label for="nickname">Nickname:</label>
          <input class="form-input" id="nickname" name="nickname" placeholder="Nickname" required />
        </div>
        
        <div class="form-group">
          <label for="email">Email:</label>
          <input class="form-input" id="email" name="email" type="email" placeholder="Email" required />
        </div>
        
        <div class="form-group">
          <label for="password">Password:</label>
          <input class="form-input" id="password" type="password" name="password" placeholder="Password (min 6 characters)" required />
        </div>
        
        <button type="submit" class="btn-primary">Sign Up</button>
      </form>
      
      <div class="form-link">
        Already have an account? <a href="/login">Login here</a>
      </div>
    </div>
  </main>

  <script src="/js/main.js"></script>
</body>
</html>