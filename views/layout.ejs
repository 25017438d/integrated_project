<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Lost & Found</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/styles.css" />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <a href="/" class="navbar-brand">Lost &amp; Found</a>
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="nav-links navbar-nav">
            <li class="nav-item">
              <a href="/" class="nav-link">Home</a>
            </li>
            <li class="nav-item">
              <a href="/notices" class="nav-link">All Notices</a>
            </li>
            <% if (user) { %>
              <li class="nav-item">
                <a href="/notices/my" class="nav-link">My Notices</a>
              </li>
              <li class="nav-item">
                <a href="/notices/new" class="nav-link">Create Notice</a>
              </li>
              <li class="nav-user">
                <a href="/profile" class="nav-link">Profile</a>
              </li>
            <% } %>
          </ul>

          <ul class="nav-links navbar-nav ms-auto">
            <% if (user) { %>
              <li class="nav-user d-flex align-items-center">
                <span class="username text-light me-3">Welcome, <%= user.nickname %></span>
                <a href="/logout" class="btn btn-outline-light btn-sm btn-logout">Logout</a>
              </li>
            <% } else { %>
              <li class="nav-item">
                <a href="/login" class="nav-link">Login</a>
              </li>
              <li class="nav-item">
                <a href="/register" class="nav-link">Register</a>
              </li>
            <% } %>
          </ul>
        </div>
      </div>
    </nav>

    <% if (error && error.length > 0) { %>
      <div class="flash-wrapper container mt-3">
        <% error.forEach(msg => { %>
          <div class="alert alert-danger alert-dismissible fade show flash-alert" role="alert">
            <%= msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% }) %>
      </div>
    <% } %>

    <% if (success && success.length > 0) { %>
      <div class="flash-wrapper container mt-3">
        <% success.forEach(msg => { %>
          <div class="alert alert-success alert-dismissible fade show flash-alert" role="alert">
            <%= msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% }) %>
      </div>
    <% } %>

    <main class="container mt-4"><%- body %></main>
    
    <!-- Bootstrap JS Bundle for responsive toggler support -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/main.js"></script>
  </body>
</html>
