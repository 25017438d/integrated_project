<%- include('layout', { user: user, body: `
<div class="notices-page">
  <div class="notices-header">
    <h2>Create Notice</h2>
    <div class="search-box">
      <!-- Empty div for consistent spacing/alignment -->
    </div>
  </div>

  <form action="/notices/new" method="POST" enctype="multipart/form-data" class="form-container notice-form">
    <div class="form-group">
      <label for="type">Type:</label>
      <select name="type" id="type" required class="form-input">
        <option value="">Select Type</option>
        <option value="lost">Lost</option>
        <option value="found">Found</option>
      </select>
    </div>

    <div class="form-group">
      <label for="date">Date:</label>
      <input type="date" name="date" id="date" required class="form-input" value="${new Date().toISOString().split('T')[0]}" />
    </div>

    <div class="form-group">
      <label for="venue">Location:</label>
      <input type="text" name="venue" id="venue" placeholder="Where did you lose/find it?" required class="form-input" />
    </div>

    <div class="form-group">
      <label for="contact">Contact Info:</label>
      <input type="text" name="contact" id="contact" placeholder="Phone or Email" required class="form-input" />
    </div>

    <div class="form-group">
      <label for="description">Description:</label>
      <textarea name="description" id="description" placeholder="Describe the item in detail" required class="form-input" rows="5"></textarea>
    </div>

    <div class="form-group">
      <label for="image">Upload Image:</label>
      <input type="file" name="image" id="image" accept="image/*" class="form-input" />
    </div>

    <button type="submit" class="btn-primary">Post Notice</button>
  </form>
</div>
` }) %>
