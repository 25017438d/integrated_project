<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Notice</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>
  <nav>
    <a href="/">Home</a>
    <a href="/notices">Notices</a>
    <a href="/notices/new">Create Notice</a>
    <% if (user) { %>
      <a href="/profile">Profile</a>
      <a href="/logout">Logout (<%= user.nickname %>)</a>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    <% } %>
  </nav>
  <main>
    <div class="form-container">
      <h2>Create Notice</h2>
      <form action="/notices/new" method="POST" enctype="multipart/form-data" class="notice-form">
        <div class="form-group">
          <label for="type">Type:</label>
          <select name="type" id="type" required class="form-input">
            <option value="">Select Type</option>
            <option value="lost">Lost</option>
            <option value="found">Found</option>
          </select>
        </div>

        <div class="form-group">
          <label for="venue">Location:</label>
          <input type="text" name="venue" id="venue" placeholder="Where did you lose/find it?" required class="form-input" />
        </div>

        <div class="form-group">
          <label for="contact">Contact Info:</label>
          <input type="text" name="contact" id="contact" placeholder="Phone or Email" required class="form-input" />
        </div>

        <div class="form-group">
          <label for="description">Description:</label>
          <textarea name="description" id="description" placeholder="Describe the item in detail" required class="form-input" rows="5"></textarea>
        </div>

        <div class="form-group">
          <label for="image">Upload Image:</label>
          <input type="file" name="image" id="image" accept="image/*" class="form-input" />
        </div>

        <button type="submit" class="btn-primary">Post Notice</button>
      </form>
    </div>
  </main>

  <script src="/js/main.js"></script>
</body>
</html>