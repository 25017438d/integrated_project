<%- include('layout', { user: user, body: `
<div class="notices-page">
  <div class="notices-header">
    <h2>${pageTitle}</h2>
    <div class="search-box">
      <input type="text" id="searchInput" placeholder="🔍 Search by item or location..." />
    </div>
  </div>

  <ul id="noticesList">
    ${notices.map(n => `
      <li class="notice">
        <div class="notice-header">
          <strong>[${String(n.type || '').toUpperCase()}]</strong>

          <div class="notice-actions">
            ${
              (user && n.owner && String(user._id) === String(n.owner._id))
                ? `<button class="btn btn-sm btn-danger notice-delete-btn" data-id="${n._id}">Delete</button>`
                : ``
            }
            
            <button
              class="btn btn-sm notice-view-btn"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#view-${n._id}"
            >
              View
            </button>

            ${
              user
                ? `
                  <button
                    class="btn btn-sm notice-respond-btn"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#respond-${n._id}"
                  >
                    Respond
                  </button>
                `
                : ``
            }

          </div>
        </div>

        <p><strong>${n.description ?? ''}</strong> — by ${n.owner?.nickname || 'Anonymous'}</p>

        <div class="collapse mt-3" id="view-${n._id}">
          ${
            n.image
              ? `<img class="notice-image" src="${n.image}" width="100" />`
              : ``
          }

          <p>
            <small>
              📅 ${n.date ? new Date(n.date).toLocaleString([], {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
              }) : ''} |
              📍 ${n.venue ?? ''} |
              📞 ${n.contact ?? ''}
            </small>
          </p>

          <div class="responses">
            <h4>Replies (${(n.responses && n.responses.length) ? n.responses.length : 0}):</h4>

            ${
              (n.responses && n.responses.length > 0)
                ? n.responses.map(r => `
                    <div class="response">
                      <strong>${r.user ? (r.user.nickname || 'Anonymous') : 'Anonymous'}</strong>:
                      ${r.message ?? ''}
                      <small>${r.date ? new Date(r.date).toLocaleString([], {
                        month: 'short',
                        day: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit'
                      }) : ''}</small>
                    </div>
                  `).join('')
                : `<p>No replies yet</p>`
            }
          </div>
        </div>

        ${
          user
            ? `
              <div class="collapse mt-3" id="respond-${n._id}">
                <form method="POST" action="/notices/${n._id}/reply" class="reply-form">
                  <input type="text" name="message" placeholder="Add a reply..." required />
                  <button type="submit" class="btn btn-primary">Reply</button>
                </form>
              </div>
            `
            : `<p><a href="/login">Login</a> to reply</p>`
        }
      </li>
    `).join('')}
  </ul>
</div>

<div id="imageModal" class="modal">
  <span class="modal-close">&times;</span>
  <img class="modal-content" id="modalImage" src="" />
</div>
` }) %>
