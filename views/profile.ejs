<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="alert alert-error">
      <% error.forEach(msg => { %>
        <div><%= msg %></div>
      <% }); %>
    </div>
  <% } %>
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="alert alert-success">
      <% success.forEach(msg => { %>
        <div><%= msg %></div>
      <% }); %>
    </div>
  <% } %>
  <nav>
    <a href="/">Home</a>
    <a href="/notices">Notices</a>
    <a href="/notices/new">Create Notice</a>
    <% if (user) { %>
      <a href="/profile">Profile</a>
      <a href="/logout">Logout (<%= user.nickname %>)</a>
    <% } else { %>
      <a href="/login">Login</a>
      <a href="/register">Register</a>
    <% } %>
  </nav>
  <main>

  <div class="profile-container">
    <div class="profile-card">
      <h2>My Profile</h2>

      <!-- Profile Picture Section - Click to Upload -->
      <div class="profile-picture-section">
        <form id="profileImageForm" method="POST" action="/profile/update-image" enctype="multipart/form-data" style="width: 100%;">
          <div class="current-picture" id="profilePictureContainer" style="cursor: pointer;">
            <% if (user.profile_image) { %>
              <img src="<%= user.profile_image %>" alt="<%= user.nickname %>" class="profile-picture" title="Click to change picture">
            <% } else { %>
              <div class="profile-picture-placeholder" title="Click to upload picture">
                <span>📷</span>
              </div>
            <% } %>
            <p class="upload-hint">Click to change picture</p>
          </div>

          <input type="file" id="profileImage" name="profileImage" accept="image/*" style="display: none;">
          <div id="imageError" class="form-error" aria-live="polite"></div>
        </form>
      </div>

      <!-- Account Information Section -->
      <div class="profile-section">
        <h3>Account Information</h3>
        <form method="POST" action="/profile/update" class="profile-form">
          <div class="form-group">
            <label for="login_id">Login ID:</label>
            <input type="text" id="login_id" value="<%= user.login_id %>" disabled class="form-input">
            <small>(Cannot be changed)</small>
          </div>

          <div class="form-group">
            <label for="nickname">Nickname:</label>
            <input type="text" id="nickname" name="nickname" value="<%= user.nickname %>" required class="form-input">
            <small>At least 2 characters</small>
          </div>

          <div class="form-group">
            <label for="email">Email:</label>
            <input type="email" id="email" name="email" value="<%= user.email %>" required class="form-input">
            <small>Must be a valid email address</small>
          </div>

          <button type="submit" class="btn-primary">Save Changes</button>
        </form>
      </div>

      <!-- Password Change Section -->
      <div class="profile-section">
        <h3>Change Password</h3>
        <form id="passwordForm" method="POST" action="/profile/update-password" class="profile-form">
          <div class="form-group">
            <label for="currentPassword">Current Password:</label>
            <input type="password" id="currentPassword" name="currentPassword" required class="form-input">
          </div>

          <div class="form-group">
            <label for="newPassword">New Password:</label>
            <input type="password" id="newPassword" name="newPassword" required class="form-input">
            <small>At least 6 characters</small>
          </div>

          <div class="form-group">
            <label for="confirmPassword">Confirm New Password:</label>
            <input type="password" id="confirmPassword" name="confirmPassword" required class="form-input">
          </div>

          <div id="passwordError" class="form-error" aria-live="polite"></div>
          <button type="submit" class="btn-primary">Update Password</button>
        </form>
      </div>

      <!-- Member Since -->
      <div class="member-info">
        <p><strong>Member Since:</strong> <span><%= new Date(user.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span></p>
      </div>
    </div>
  </main>

  <script src="/js/main.js"></script>
  <script>
    // Make profile picture clickable to upload and validate password client-side
    document.addEventListener('DOMContentLoaded', () => {
      const profileContainer = document.getElementById('profilePictureContainer');
      const fileInput = document.getElementById('profileImage');
      const form = document.getElementById('profileImageForm');

      if (profileContainer && fileInput) {
        profileContainer.addEventListener('click', () => {
          fileInput.click();
        });

        // Auto-submit form when file is selected
        fileInput.addEventListener('change', (e) => {
          if (e.target.files && e.target.files.length > 0) {
            form.submit();
          }
        });
      }

      // Client-side password complexity check (inline errors)
      const passwordForm = document.getElementById('passwordForm');
      const passwordError = document.getElementById('passwordError');
      if (passwordForm) {
        passwordForm.addEventListener('submit', (e) => {
          const newPassword = document.getElementById('newPassword').value;
          const confirmPassword = document.getElementById('confirmPassword').value;
          const complexity = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[\W_]).{8,}$/;
          passwordError.textContent = '';

          if (newPassword !== confirmPassword) {
            e.preventDefault();
            passwordError.textContent = 'New passwords do not match.';
            return;
          }

          if (!complexity.test(newPassword)) {
            e.preventDefault();
            passwordError.textContent = 'Password must be at least 8 characters and include uppercase, lowercase, number, and special character.';
            return;
          }
        });
      }

      // Client-side image validation before auto-submit (2MB max, image types only)
      const imageError = document.getElementById('imageError');
      if (fileInput) {
        fileInput.addEventListener('change', (e) => {
          imageError.textContent = '';
          const file = e.target.files && e.target.files[0];
          if (!file) return;

          const maxBytes = 2 * 1024 * 1024; // 2MB
          if (!file.type.startsWith('image/')) {
            imageError.textContent = 'Selected file is not an image.';
            fileInput.value = '';
            return;
          }
          if (file.size > maxBytes) {
            imageError.textContent = 'Image is too large (max 2MB).';
            fileInput.value = '';
            return;
          }

          // If all good, submit
          form.submit();
        });
      }
    });
  </script>
</body>
</html>
